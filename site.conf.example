# ==================================================
# Lunar Linux Website Configuration
# ==================================================

# --------------------------------------------------
# Directories
# --------------------------------------------------

SITE_ROOT="."
SRC_DIR="src"
MARKDOWN_DIR="src/markdown"
NEWS_DIR="src/news"

TEMPLATES_DIR="templates"
TOOLS_DIR="tools"

PUBLIC_DIR="public"
DATA_DIR="public/data"

# --------------------------------------------------
# Local repositories
# --------------------------------------------------

MOONBASE_DIR="../moonbase"

# --------------------------------------------------
# External resources
# --------------------------------------------------

ISO_BASE_URL="https://lunar.lart.ca/latest"
IRC_URL="https://web.libera.chat/#lunar"
WIKI_URL="http://wiki.lunar-linux.org"

# --------------------------------------------------
# Generated files
# --------------------------------------------------

MOONBASE_STATS_JSON="public/data/moonbase-stats.json"
DAILY_ISO_JSON="public/data/daily-iso.json"
NEWS_JSON="public/data/news.json"

# --------------------------------------------------
# Build options
# --------------------------------------------------

GENERATE_NEWS_JSON="yes"
GENERATE_RSS="no"
UPDATE_DYNAMIC_DATA="yes"
